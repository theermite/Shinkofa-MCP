# At least one is required:
# API key for public data (videos, channels, search)
YOUTUBE_API_KEY=your_api_key_here

# OAuth2 access token for private data (upload, update, delete, live)
# GOOGLE_ACCESS_TOKEN=ya29.xxx

# Optional — Override API base URL (default: https://www.googleapis.com/youtube/v3)
# YOUTUBE_API_BASE_URL=https://www.googleapis.com/youtube/v3

# Optional — Request timeout in milliseconds (default: 30000)
# YOUTUBE_TIMEOUT_MS=30000
