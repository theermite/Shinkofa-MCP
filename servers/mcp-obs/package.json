{
  "name": "@shinkofa/mcp-obs",
  "version": "1.0.0",
  "description": "MCP server for OBS Studio — scenes, sources, streaming, recording, filters via WebSocket v5",
  "author": "Jay The Ermite <jay@shinkofa.com>",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-obs": "dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "obs-websocket-js": "^5.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0",
    "@vitest/coverage-v8": "^3.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
