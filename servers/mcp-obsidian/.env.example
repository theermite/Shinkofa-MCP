# Required — Obsidian Local REST API key (from the plugin settings)
OBSIDIAN_API_KEY=your_api_key_here

# Optional — Override API base URL (default: https://127.0.0.1:27124)
# OBSIDIAN_API_URL=https://127.0.0.1:27124

# Optional — Request timeout in milliseconds (default: 15000)
# OBSIDIAN_TIMEOUT_MS=15000
