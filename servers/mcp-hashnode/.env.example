# Required — Hashnode Personal Access Token (from https://hashnode.com/settings/developer)
HASHNODE_PAT=your-pat-here

# Optional — Override GraphQL endpoint (default: https://gql.hashnode.com)
# HASHNODE_ENDPOINT=https://gql.hashnode.com

# Optional — Request timeout in milliseconds (default: 30000)
# HASHNODE_TIMEOUT_MS=30000
