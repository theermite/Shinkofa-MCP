# Required — Twitch Application Client ID (from dev.twitch.tv)
TWITCH_CLIENT_ID=your_client_id_here

# One of these is required:
# Client secret for app access token (auto-refreshed)
TWITCH_CLIENT_SECRET=your_client_secret_here

# Or a user access token (for user-scoped actions)
# TWITCH_ACCESS_TOKEN=your_access_token_here

# Optional — Override API base URL (default: https://api.twitch.tv/helix)
# TWITCH_API_BASE_URL=https://api.twitch.tv/helix

# Optional — Request timeout in milliseconds (default: 30000)
# TWITCH_TIMEOUT_MS=30000
