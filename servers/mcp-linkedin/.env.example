# LinkedIn OAuth2 access token (required)
# Obtain via OAuth2 flow with w_member_social scope
# Tokens expire after 60 days
LINKEDIN_ACCESS_TOKEN=your_access_token_here

# LinkedIn API version (optional, defaults to 202603)
# LINKEDIN_API_VERSION=202603

# Request timeout in ms (optional, defaults to 30000)
# LINKEDIN_TIMEOUT_MS=30000
