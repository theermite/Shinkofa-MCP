{
  "name": "@shinkofa/mcp-shared",
  "version": "1.2.0",
  "description": "Shared utilities for Shinkofa MCP servers — toolResult, toolError, createErrorHandler, connectTransport",
  "author": "Jay The Ermite",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "test": "cross-env NODE_OPTIONS=--max-old-space-size=2048 vitest run",
    "test:watch": "vitest",
    "test:coverage": "cross-env NODE_OPTIONS=--max-old-space-size=2048 vitest run --coverage",
    "lint": "biome check src/ tests/",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.1.0",
    "cross-env": "^7.0.3",
    "fast-check": "^4.7.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  },
  "publishConfig": {
    "registry": "https://npm.shinkofa.com",
    "access": "restricted"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  }
}
